# =============================================================================
# edu-knowledge 导入图（LangGraph）实际读取的变量
# 复制为 .env 后按需填写；除注明外均可留空使用默认值。
#
# 联调单次导入（单 Markdown 文件）::
#   pip install -r requirements.txt
#   python run_import_once.py 你的文件.md
#
# run_import_once 使用 load_dotenv(override=True)，项目根 .env 会覆盖 conda/系统里
# 已存在的同名变量（避免 MILVUS_URI、LLM_DEFAULT_MODEL 等被旧环境覆盖）。
# Milvus 连通性可单独测：python milvus_ping.py
# =============================================================================

# --- LLM（分类、抽取节点）---
# 必填：无密钥时无法调用分类/抽取（与 Embedding 可共用同一 key）
ACTIVE_API_KEY=sk-qmvidinfujwkrwfeseijnqqakjwksdixwozvkeezmnzshbas
# 可选：直连 OpenAI 可不填；SiliconFlow / 自建网关等需填 Base URL
# SiliconFlow 的 LLM_DEFAULT_MODEL 须与控制台「模型名」一致，含厂商前缀，例如：
#   deepseek-ai/DeepSeek-V3、Qwen/Qwen2.5-7B-Instruct
# 勿使用简称（如 DeepSeek-V3），否则会报 Model does not exist。
ACTIVE_API_BASE=https://api.siliconflow.cn/v1
LLM_DEFAULT_MODEL=deepseek-ai/DeepSeek-V3

# --- Word 转 MD（file_router，python-docx）---
# 由 requirements.txt 的 python-docx 解析 .docx，无需额外配置。

# --- PDF（file_router → processor/pdf_magic.py，MinerU / magic-pdf CLI）---
# true/1 时调用本机 magic-pdf（PATH 或 PDF_MAGIC_CMD 绝对路径）；MAGIC_PDF_CONFIG 指向 magic-pdf.json
PDF_IMPORT_ENABLED=false
# PDF_MAGIC_CMD=magic-pdf
# MAGIC_PDF_CONFIG=E:\path\to\magic-pdf.json
# PDF_MAGIC_MODE=auto
# PDF_MAGIC_TIMEOUT=600

# --- Markdown 切分（lecture / syllabus；对齐 knowledge document_split_node）---
# 二级切分最大长度、合并过短段阈值；须 max > min
# DOC_SPLIT_MAX_LENGTH=4000
# DOC_SPLIT_MIN_LENGTH=400

# --- Milvus（vector_indexer、init_milvus）---
# 连接串：与运行 python 的「同一台机器」上的 Milvus → http://127.0.0.1:19530
# 若 Milvus 跑在虚拟机/远程服务器：必须填从本机可达的 IP，勿用 127.0.0.1 指代虚拟机。
#   例：MILVUS_URI=http://192.168.56.101:19530（按你的网段改 IP）
# Milvus Lite 文件库示例：./milvus_edu.db
# 兼容别名：MILVUS_URL（与 MILVUS_URI 二选一即可）
MILVUS_URI=http://127.0.0.1:19530
# MILVUS_URL=
# Zilliz Cloud 等需要时填写
MILVUS_TOKEN=
# gRPC channel ready 等待时间（秒），远程/虚拟机建议 90～120
# MILVUS_TIMEOUT=90
# 本机有 Clash 等代理时，gRPC 连局域网 Milvus 常被干扰；建议保持为 1（run_import_once / init_milvus 会在 load_dotenv 后生效）
MILVUS_DISABLE_PROXY=1

# --- 入库模式 ---
# legacy（默认）：单表 + OpenAI 兼容 Embedding，字段名 vector
# v2：双表 + 本地 BGE-M3 稠密/稀疏，需 FlagEmbedding+torch
MILVUS_RAG_MODE=legacy
# v2 下 /search/documents 与对话 doc_search：HyDE（LLM 假设文档 + RRF）、BGE 精排 + 悬崖截断（可选）
# SEARCH_DOCUMENT_HYDE=0
# SEARCH_DOCUMENT_RERANK=0
# CHAT_DOC_SEARCH_HYDE=0
# CHAT_DOC_SEARCH_RERANK=0
# SEARCH_HYDE_BRANCH_LIMIT=20
# 多轮追问指代消解节点（query_rewrite_node）；设为 1/true 则关闭改写
# QUERY_REWRITE_DISABLED=0
# legacy 下的集合名
MILVUS_COLLECTION=edu_knowledge_vectors_v1
# 仅 OpenAI 兼容 Embedding 时填写 legacy 维度（text-embedding-3-small → 1536）；本地 BGE 时忽略，以 BGE_M3_DIM 为准
# MILVUS_LEGACY_VECTOR_DIM=1536
# v2 双表（默认名，避免与其它项目 kb_* 冲突）
MILVUS_NAMES_COLLECTION=edu_knowledge_item_names_v1
MILVUS_CHUNKS_COLLECTION=edu_knowledge_chunks_v1

# 建表脚本 init_milvus.py：为 1 时删库重建（慎用）
MILVUS_INIT_DROP=0
# BGE-M3 稠密维度，需与模型一致（bge-m3 一般为 1024）
BGE_M3_DIM=1024

# 跳过去重查询（调试或全量重灌时可开）
MILVUS_SKIP_DEDUP=0

# --- Embedding ---
# - 留空且 ``BGE_M3_PATH`` 为已存在目录 → 自动用本地 BGE-M3（不调 API）
# - ``EMBEDDING_BACKEND=openai`` → 强制 OpenAI 兼容 Embedding API（即使有 BGE_M3_PATH）
# - ``EMBEDDING_BACKEND=local_bge_m3`` / ``local`` / ``offline`` → 强制本地
EMBEDDING_BACKEND=

# OpenAI 兼容 Embedding（仅当未使用本地 BGE 时）
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=32

# 本地 BGE-M3（FlagEmbedding，utils/local_bge_client.py）
# 优先使用目录（完全离线）；以下为示例路径，请改成你的本机路径
BGE_M3_PATH=E:\NLP\nlp_models\hub\models--BAAI--bge-m3
BGE_M3=BAAI/bge-m3
BGE_DEVICE=cuda:0
BGE_FP16=true
BGE_M3_BATCH=12
# 并发 encode 上限（HyDE/多路检索同时打 GPU 时限流）
# BGE_MAX_CONCURRENT=4
# ITEM_NAME_DIAG=1
# 若 BGE-M3 仍报 meta tensor / Cannot copy out of meta tensor：一般无需设置（代码会默认 low_cpu_mem_usage=False）
# BGE_M3_SKIP_LOAD_PATCH=0

# 本地 Reranker（查询重排用，utils/local_bge_reranker.py；导入图不强制调用）
BGE_RERANKER_LARGE=E:\NLP\nlp_models\hub\models--BAAI--bge-reranker-v2-m3
BGE_RERANKER_DEVICE=cuda:0
BGE_RERANKER_FP16=1
# 若 Reranker 仍报 meta tensor：保持 FP16=0 或 DEVICE=cpu 试排；一般无需设置（代码会为 from_pretrained 打补丁）
# BGE_RERANKER_SKIP_LOAD_PATCH=0

# --- FastAPI 服务（python run_server.py）---
# API_HOST=0.0.0.0
# API_PORT=8000

# --- MongoDB（PLAN 业务主库；导入任务 / 课程题库 / 文档回表 / 会话）---
# 二选一：MONGODB_URI 或 MONGO_URL
# MONGODB_URI=mongodb://127.0.0.1:27017
# MONGODB_DATABASE=edu_knowledge

# --- MinIO（图片对象；当前 API 骨架已留配置位，业务上传可后续接）---
# MINIO_ENDPOINT=127.0.0.1:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=education-knowledge
# MINIO_SECURE=0
# 浏览器/外链展示用（bucket 前缀已含在路径里时可只写到 bucket）
# MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9000/education-knowledge

# --- API 鉴权（可选；非空则导入/检索/对话均需 X-API-Key；SSE 可 URL ?x_api_key=）---
# API_KEYS=your-secret-key,another-key

# --- 意图分类：为 true 时每轮先走 LLM 四选一（更准、更慢、耗 token）---
# INTENT_USE_LLM=false

# =============================================================================
# 下列变量若你其它服务 / 脚本使用可保留
# =============================================================================
# REQUESTS_PER_MINUTE=15
# MILVUS_METRIC_TYPE=COSINE
# MCP_DASHSCOPE_BASE_URL=
